              "pm.test(\"time_last_update_unix is present and a number\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.time_last_update_unix).to.be.a(\"number\");",
              "});",
              "",
              "pm.test(\"time_next_update_unix is present and a number\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.time_next_update_unix).to.be.a(\"number\");",
              "});",
              "",
              "pm.test(\"Next update is after last update\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.time_next_update_unix).to.be.above(jsonData.time_last_update_unix);",
              "});",
              "",
              "pm.test(\"Last update was within the past 48 hours\", function () {",
              "    var jsonData = pm.response.json();",
              "    var now = Math.floor(Date.now() / 1000);",
              "    var fortyEightHours = 48 * 60 * 60;",
              "    pm.expect(now - jsonData.time_last_update_unix).to.be.below(fortyEightHours);",
              "});"
